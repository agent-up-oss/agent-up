{
  "name": "Agent Up",
  "applications": [
    {
      "name": "Docs",
      "command": "npm run start",
      "path": "docs",
      "ports": [
        { "variable": "PORT", "defaultPort": 3000 }
      ]
    }
  ],
  "services": [
    {
      "name": "Database",
      "image": "postgres:16",
      "ports": [
        { "variable": "POSTGRES_PORT", "defaultPort": 5432 }
      ],
      "environment": {
        "POSTGRES_PASSWORD": "secret"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"]
    }
  ]
}
