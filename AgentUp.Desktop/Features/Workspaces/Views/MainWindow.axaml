<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgentUp.Desktop.Features.Workspaces.ViewModels"
        xmlns:appVm="using:AgentUp.Desktop.Features.Applications.ViewModels"
        xmlns:portVm="using:AgentUp.Desktop.Features.Ports.ViewModels"
        x:Class="AgentUp.Desktop.Features.Workspaces.Views.MainWindow"
        x:CompileBindings="False"
        Width="1100" Height="700"
        MinWidth="640" MinHeight="400"
        Title="Agent-Up"
        WindowDecorations="None"
        Background="#020806">

    <Window.DataTemplates>
        <!-- Console sub-tab -->
        <DataTemplate DataType="portVm:ConsoleSubTabViewModel">
            <Border Classes="subTab" Padding="13,7">
                <TextBlock Text="Console"
                           Foreground="#c2d2ca"
                           FontSize="12"
                           FontWeight="Bold"/>
            </Border>
        </DataTemplate>

        <!-- Port sub-tab -->
        <DataTemplate DataType="portVm:PortSubTabViewModel">
            <Border Classes="subTab" Padding="13,7">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Border Width="6" Height="6"
                            CornerRadius="3"
                            Background="{Binding StatusColor}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Label}"
                               Foreground="#f5fbf7"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <!-- Strip default ListBox chrome -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Strip default Button chrome -->
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Integrated window chrome -->
        <Style Selector="Border.chromeButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pointerover Border.chromeButton">
            <Setter Property="Background" Value="#0d4f32"/>
        </Style>
        <Style Selector="Button:pointerover Border.chromeClose">
            <Setter Property="Background" Value="#c42b1c"/>
        </Style>
        <Style Selector="TextBlock.chromeIcon">
            <Setter Property="Foreground" Value="#f5fbf7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="LineHeight" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.chromeMinimizeIcon">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="LineHeight" Value="15"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
        </Style>
        <Style Selector="TextBlock.chromeRestoreIcon">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="LineHeight" Value="14"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>
        <Style Selector="TextBlock.chromeCloseIcon">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="LineHeight" Value="19"/>
            <Setter Property="Margin" Value="0,-5,0,0"/>
        </Style>
        <Style Selector="Border.titleToolButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pointerover Border.titleToolButton">
            <Setter Property="Background" Value="#0d4f32"/>
        </Style>

        <!-- Application tab bar -->
        <Style Selector="Border.appTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.appTab">
            <Setter Property="Background" Value="#092819"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.appTab">
            <Setter Property="Background" Value="#0a3b28"/>
            <Setter Property="BorderBrush" Value="#0f7a45"/>
        </Style>

        <!-- Sub-navbar tab -->
        <Style Selector="Border.subTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.subTab">
            <Setter Property="Background" Value="#0a2f20"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.subTab">
            <Setter Property="Background" Value="#0f7a45"/>
        </Style>

        <!-- Browser address bar -->
        <Style Selector="TextBox.addressBar">
            <Setter Property="Background" Value="#04100b"/>
            <Setter Property="BorderBrush" Value="#145a38"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Foreground" Value="#c9d7d0"/>
            <Setter Property="CaretBrush" Value="#c9d7d0"/>
            <Setter Property="SelectionBrush" Value="#0f7a45"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBox.addressBar:focus">
            <Setter Property="BorderBrush" Value="#00d66b"/>
        </Style>
        <Style Selector="Border.browserButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#082418"/>
        </Style>
        <Style Selector="Button:pointerover Border.browserButton">
            <Setter Property="Background" Value="#0d4f32"/>
        </Style>

        <!-- Workspace entry: normal / hover / selected -->
        <Style Selector="Border.wsEntry">
            <Setter Property="Background" Value="#06140f"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsEntry">
            <Setter Property="Background" Value="#0f5a38"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsEntry">
            <Setter Property="Background" Value="#0f7a45"/>
        </Style>

        <!-- Collapsed avatar: highlight selected -->
        <Style Selector="Border.wsAvatar">
            <Setter Property="Background" Value="#06140f"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsAvatar">
            <Setter Property="Background" Value="#0f5a38"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsAvatar">
            <Setter Property="Background" Value="#0f7a45"/>
        </Style>

        <!-- First-run tutorial -->
        <Style Selector="Border.tutorialButton">
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#0f7a45"/>
        </Style>
        <Style Selector="Button:pointerover Border.tutorialButton">
            <Setter Property="Background" Value="#22e17b"/>
        </Style>
        <Style Selector="Button:disabled Border.tutorialButton">
            <Setter Property="Background" Value="#143424"/>
        </Style>
        <Style Selector="Border.tutorialSecondaryButton">
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#082418"/>
            <Setter Property="BorderBrush" Value="#147346"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover Border.tutorialSecondaryButton">
            <Setter Property="Background" Value="#0d4f32"/>
        </Style>
        <Style Selector="TextBlock.tutorialButtonText">
            <Setter Property="Foreground" Value="#f5fbf7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Styles>

    <Border Background="#020806"
            BorderBrush="#0f4d32"
            BorderThickness="1">
    <Grid RowDefinitions="42,*">

        <Control x:Name="FocusSink"
                 Width="1"
                 Height="1"
                 Opacity="0"
                 Focusable="True"
                 IsHitTestVisible="False"/>

        <!-- Integrated window controls / drag surface -->
        <Border Grid.Row="0"
                x:Name="WindowChrome"
                Background="#020806"
                PointerPressed="OnWindowChromePointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <Button x:Name="SidebarToggle"
                            Command="{Binding Sidebar.ToggleCommand}"
                            ToolTip.Tip="Toggle sidebar">
                        <Border Classes="titleToolButton">
                            <TextBlock Classes="chromeIcon" Text="☰" FontSize="16"/>
                        </Border>
                    </Button>
                    <Button x:Name="ReloadButton"
                            Command="{Binding Sidebar.RefreshCommand}"
                            ToolTip.Tip="Reload workspaces">
                        <Border Classes="titleToolButton">
                            <TextBlock Classes="chromeIcon" Text="↺" FontSize="15"/>
                        </Border>
                    </Button>
                    <Border x:Name="ServerStatusBadge"
                            Margin="6,0,0,0"
                            Padding="12,5"
                            CornerRadius="999"
                            BorderBrush="{Binding Sidebar.ServerStatusColor}"
                            BorderThickness="1"
                            Background="#04100b"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="9"
                                    Height="9"
                                    CornerRadius="5"
                                    Background="{Binding Sidebar.ServerStatusColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="ServerStatusText"
                                       Text="{Binding Sidebar.ServerStatusText}"
                                       Foreground="#f5fbf7"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="Agent-Up"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#f5fbf7"
                           FontSize="13"
                           FontWeight="Bold"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="MinimizeWindowButton"
                            Click="OnMinimizeWindowClicked"
                            ToolTip.Tip="Minimize">
                        <Border Classes="chromeButton">
                            <TextBlock Classes="chromeIcon chromeMinimizeIcon" Text="─"/>
                        </Border>
                    </Button>
                    <Button x:Name="RestoreWindowButton"
                            Click="OnRestoreWindowClicked"
                            ToolTip.Tip="Restore">
                        <Border Classes="chromeButton">
                            <TextBlock Classes="chromeIcon chromeRestoreIcon" Text="□"/>
                        </Border>
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Click="OnCloseWindowClicked"
                            ToolTip.Tip="Close">
                        <Border Classes="chromeButton chromeClose">
                            <TextBlock Classes="chromeIcon chromeCloseIcon" Text="×"/>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                x:Name="SidebarRail"
                Width="{Binding Sidebar.Width}"
                Background="#030b08"
                BorderBrush="#082014"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header (expanded only) -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12,16,6"
                        IsVisible="{Binding Sidebar.IsExpanded}">
                    <TextBlock Text="Workspaces"
                               Foreground="#2bf27a"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Spacer above avatar list (collapsed only) -->
                <Border DockPanel.Dock="Top"
                        Height="14"
                        IsVisible="{Binding Sidebar.IsCollapsed}"/>

                <!-- Expanded workspace list -->
                <ScrollViewer x:Name="WorkspaceListExpanded"
                              IsVisible="{Binding Sidebar.IsExpanded}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox HorizontalAlignment="Stretch"
                             Width="{Binding #SidebarRail.Bounds.Width}"
                             ItemsSource="{Binding Sidebar.Workspaces}"
                             SelectedItem="{Binding Sidebar.SelectedWorkspace}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border Padding="10,2"
                                        HorizontalAlignment="Stretch">
                                    <Border Classes="wsEntry"
                                            CornerRadius="8"
                                            Padding="14,10"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="{Binding RepositoryToolTip}">
                                        <StackPanel Spacing="3">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left"
                                                        Width="6" Height="6"
                                                        CornerRadius="3"
                                                        Background="{Binding StateColor}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,7,0"/>
                                                <TextBlock Text="{Binding RepositoryName}"
                                                           Foreground="#f5fbf7"
                                                           FontSize="15"
                                                           FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Branch}"
                                                       Foreground="#9fb2a8"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Collapsed avatar list -->
                <ScrollViewer x:Name="WorkspaceListCollapsed"
                              IsVisible="{Binding Sidebar.IsCollapsed}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox
                             ItemsSource="{Binding Sidebar.Workspaces}"
                             SelectedItem="{Binding Sidebar.SelectedWorkspace}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border HorizontalAlignment="Center" Padding="0,4">
                                    <Border Classes="wsAvatar"
                                            Width="36" Height="36"
                                            CornerRadius="18"
                                            ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="#f5fbf7"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ── Main content ───────────────────────────────────────────────────── -->
        <Border Grid.Column="1" Background="#020806">
            <Panel>

                <!-- Loading -->
                <TextBlock x:Name="LoadingIndicator"
                           IsVisible="{Binding Sidebar.IsLoading}"
                           Text="Connecting to server…"
                           Foreground="#2bf27a"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Error -->
                <Panel x:Name="ErrorPanel"
                       IsVisible="{Binding Sidebar.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#140f0f"
                            BorderBrush="#552d2d"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24,20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="{Binding Sidebar.ErrorMessage}"
                                       Foreground="#e48989"
                                       FontSize="13"/>
                            <Button Command="{Binding Sidebar.RefreshCommand}"
                                    HorizontalAlignment="Center">
                                <Border Background="#0f7a45" CornerRadius="7" Padding="14,7">
                                    <TextBlock Text="Retry" Foreground="#f5fbf7" FontSize="12"/>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>
                </Panel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            IsVisible="{Binding Sidebar.ShowEmptyState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="No workspaces registered"
                               Foreground="#2bf27a"
                               FontSize="16"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Run  agent-up register  in your project directory to get started."
                               Foreground="#789085"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Workspace detail: app tabs + sub-navbar + content -->
                <Border x:Name="WorkspaceDetail"
                        IsVisible="{Binding Sidebar.SelectedWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Grid RowDefinitions="Auto,Auto,Auto,*">

                        <!-- Application tab bar -->
                        <Border Grid.Row="0"
                                Background="#05180f"
                                BorderBrush="#0d3827"
                                BorderThickness="0,0,0,1">
                            <ListBox x:Name="ApplicationTabs"
                                     ItemsSource="{Binding Applications.Applications}"
                                     SelectedItem="{Binding Applications.SelectedApplication}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="appVm:ApplicationViewModel">
                                        <Border Classes="appTab" Padding="18,13">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="6" Height="6" CornerRadius="3"
                                                        Background="{Binding StateColor}"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#c2d2ca"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Sub-navbar: Console + port tabs for the selected app -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding Applications.SelectedApplication, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="#04130d"
                                BorderBrush="#0d3827"
                                BorderThickness="0,0,0,1"
                                Padding="14,8">
                            <ListBox x:Name="SubNavBar"
                                     ItemsSource="{Binding SubTabs}"
                                     SelectedItem="{Binding SelectedSubTab}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <!-- Templates resolved from Window.DataTemplates by type -->
                            </ListBox>
                        </Border>

                        <!-- Browser address bar for HTTP port tabs -->
                        <Border Grid.Row="2"
                                x:Name="AddressNavBar"
                                IsVisible="{Binding ShowPortView}"
                                Background="#04100b"
                                BorderBrush="#0d3827"
                                BorderThickness="0,0,0,1"
                                Padding="16,7">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                                  ColumnSpacing="6">
                                <Button Grid.Column="0"
                                        x:Name="BrowserBackButton"
                                        Command="{Binding BrowserBackCommand}"
                                        ToolTip.Tip="Back">
                                    <Border Classes="browserButton">
                                        <TextBlock Text="‹"
                                                   Foreground="#d3eadf"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Button>
                                <Button Grid.Column="1"
                                        x:Name="BrowserForwardButton"
                                        Command="{Binding BrowserForwardCommand}"
                                        ToolTip.Tip="Forward">
                                    <Border Classes="browserButton">
                                        <TextBlock Text="›"
                                                   Foreground="#d3eadf"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Button>
                                <Button Grid.Column="2"
                                        x:Name="BrowserReloadButton"
                                        Command="{Binding BrowserReloadCommand}"
                                        ToolTip.Tip="Reload">
                                    <Border Classes="browserButton">
                                        <TextBlock Text="↺"
                                                   Foreground="#d3eadf"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Button>
                                <TextBox Grid.Column="3"
                                         x:Name="AddressBar"
                                         Classes="addressBar"
                                         Text="{Binding AddressBarUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         HorizontalAlignment="Stretch">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter"
                                                    Command="{Binding NavigateAddressCommand}"/>
                                    </TextBox.KeyBindings>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Content area -->
                        <Panel Grid.Row="3">

                            <!-- No applications configured -->
                            <StackPanel IsVisible="{Binding Applications.SelectedApplication, Converter={x:Static ObjectConverters.IsNull}}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="No apps in this workspace"
                                           Foreground="#6f857a"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Add an agent-up.json with an applications list."
                                           Foreground="#52685d"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Console output — populated by code-behind with a NativeWebView -->
                            <Grid IsVisible="{Binding ShowConsole}"
                                  RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0"
                                           IsVisible="{Binding Console.WasTruncated}"
                                           Text="Server output was capped at 50,000 lines."
                                           Foreground="#789085"
                                           FontSize="11"
                                           Margin="20,8,20,0"/>
                                <Panel x:Name="ConsolePane" Grid.Row="1" />
                                <StackPanel Grid.Row="2"
                                            IsVisible="{Binding Console.HasHiddenLines}"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            Margin="20,6,20,6">
                                    <TextBlock Foreground="#789085"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Text="Showing last 2,000 lines."/>
                                    <Button Command="{Binding Console.ShowMoreCommand}"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Foreground="#0f7a45"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Content="Show all"/>
                                </StackPanel>
                            </Grid>

                            <!-- Port view: browser WebViews are added/swapped here in code-behind -->
                            <Panel x:Name="PortPane"
                                   IsVisible="{Binding ShowPortView}">
                                <!-- Shown only when NativeWebView creation fails for the active workspace -->
                                <Border x:Name="WebViewErrorBanner"
                                        IsVisible="False"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#140f0f"
                                        BorderBrush="#552d2d"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="24,20">
                                    <TextBlock x:Name="WebViewErrorText"
                                               Foreground="#e48989"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               MaxWidth="400"/>
                                </Border>
                            </Panel>

                            <!-- TCP port placeholder -->
                            <StackPanel IsVisible="{Binding ShowTcpInfo}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="TCP port"
                                           Foreground="#6f857a"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="This port is not an HTTP service."
                                           Foreground="#52685d"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                        </Panel>

                    </Grid>
                </Border>

            </Panel>
        </Border>
        </Grid>

        <Panel Grid.RowSpan="2"
               x:Name="FirstRunTutorialOverlay"
               IsVisible="{Binding Tutorial.IsVisible}"
               IsHitTestVisible="{Binding Tutorial.IsVisible}">
            <Border Background="#CC020806"/>
            <Border Background="#6607110f">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>

            <Grid RowDefinitions="*,8*,*"
                  ColumnDefinitions="*,8*,*">
            <Border Grid.Row="1"
                    Grid.Column="1"
                    MinWidth="480"
                    MinHeight="320"
                    MaxWidth="900"
                    MaxHeight="620"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#04130d"
                    BorderBrush="#00d66b"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Spacing="6">
                        <TextBlock Text="Agent-Up first run"
                                   Foreground="#f5fbf7"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Set up a complete two-workspace JavaScript demo before entering the app."
                                   Foreground="#acd0bd"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,22,0,22"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="18">
                            <StackPanel IsVisible="{Binding Tutorial.ShowDockerStep}" Spacing="16">
                                <TextBlock Text="Step 1: Install Docker and Agent-Up"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="Agent-Up needs "/>
                                    <Run Text="Docker" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" for database services and "/>
                                    <Run Text="Agent-Up CLI" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" to register workspaces with the Server."/>
                                </TextBlock>
                                <Button x:Name="TutorialCheckPrerequisitesButton"
                                        Command="{Binding Tutorial.CheckDockerCommand}"
                                        HorizontalAlignment="Left">
                                    <Border Classes="tutorialSecondaryButton">
                                        <TextBlock Classes="tutorialButtonText" Text="Check Prerequisites"/>
                                    </Border>
                                </Button>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowEnvironmentStep}" Spacing="16">
                                <TextBlock Text="Step 2: Choose a development environment"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="Choose the stack Agent-Up should prove end-to-end. The JavaScript path builds a "/>
                                    <Run Text="real React + Express + Postgres workspace" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=", then duplicates it to prove port isolation."/>
                                </TextBlock>
                                <Grid ColumnDefinitions="*,*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="12">
                                    <Button Grid.Column="0"
                                            x:Name="TutorialSelectJavaScriptButton"
                                            Command="{Binding Tutorial.SelectJavaScriptCommand}">
                                        <Border Background="#082418" BorderBrush="#00d66b" BorderThickness="1" CornerRadius="8" Padding="16">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="JS"
                                                           Foreground="#f4dd4b"
                                                           FontSize="30"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="Node + JavaScript" Foreground="#f5fbf7" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="React SPA, Express API, Postgres" Foreground="#acd0bd" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                    <Border Grid.Column="1" Background="#04100b" BorderBrush="#11683f" BorderThickness="1" CornerRadius="8" Padding="16" Opacity="0.62">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text=".NET" Foreground="#8bb7ff" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text=".NET" Foreground="#f5fbf7" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Coming later" Foreground="#acd0bd" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#04100b" BorderBrush="#11683f" BorderThickness="1" CornerRadius="8" Padding="16" Opacity="0.62">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="PY" Foreground="#ffd66b" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Python" Foreground="#f5fbf7" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Coming later" Foreground="#acd0bd" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowNodeStep}" Spacing="16">
                                <TextBlock Text="Step 3: Install Node.js 20+"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="The sample apps run on "/>
                                    <Run Text="Node.js 20 or newer" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" with npm. If you install Node while Agent-Up Desktop is open, restart Desktop so it receives the updated PATH."/>
                                </TextBlock>
                                <Button x:Name="TutorialCheckNodeButton"
                                        Command="{Binding Tutorial.CheckNodeCommand}"
                                        HorizontalAlignment="Left">
                                    <Border Classes="tutorialSecondaryButton">
                                        <TextBlock Classes="tutorialButtonText" Text="Check Node"/>
                                    </Border>
                                </Button>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowSampleStep}" Spacing="16">
                                <TextBlock Text="Step 4: Create project files"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="Agent-Up Desktop creates "/>
                                    <Run Text="example-agent1" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" under /tmp/&lt;random-guid&gt;/agent-up-tutorial/ with a React app, an Express API, and docker-compose.yaml for Postgres."/>
                                </TextBlock>
                                <Button x:Name="TutorialCreateProjectFilesButton"
                                        Command="{Binding Tutorial.CreateSampleProjectCommand}"
                                        HorizontalAlignment="Left">
                                    <Border Classes="tutorialSecondaryButton">
                                        <TextBlock Classes="tutorialButtonText" Text="Create Project Files"/>
                                    </Border>
                                </Button>
                                <StackPanel IsVisible="{Binding Tutorial.ShowProjectFileCheckSection}"
                                            Spacing="10"
                                            Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Tutorial.ProjectDirectory}"
                                               Foreground="#d3eadf"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="These are the files Agent-Up will manage. The smoke check confirms the project shape is complete."
                                               Foreground="#acd0bd"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                    <TextBox IsVisible="{Binding Tutorial.ShowDirectoryTree}"
                                             Text="{Binding Tutorial.DirectoryTree}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             MinHeight="130"
                                             Background="#020806"
                                             BorderBrush="#11683f"
                                             Foreground="#dcf3e7"
                                             Padding="12"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button x:Name="OpenTutorialFolderButton"
                                                Click="OnOpenTutorialFolderClicked">
                                            <Border Classes="tutorialSecondaryButton">
                                                <TextBlock Classes="tutorialButtonText" Text="Open File Explorer"/>
                                            </Border>
                                        </Button>
                                        <Button x:Name="TutorialCheckProjectFilesButton"
                                                Command="{Binding Tutorial.CheckProjectFilesCommand}">
                                            <Border Classes="tutorialSecondaryButton">
                                                <TextBlock Classes="tutorialButtonText" Text="Check Project Files"/>
                                            </Border>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowAgentUpJsonStep}" Spacing="16">
                                <TextBlock Text="Step 5: Create agent-up.json"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="agent-up.json is the "/>
                                    <Run Text="contract between your project and Agent-Up" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=". It declares the two Node apps and starts Postgres with docker compose."/>
                                </TextBlock>
                                <TextBox Text="{Binding Tutorial.Snippet}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas,Courier New,monospace"
                                         FontSize="12"
                                         MinHeight="220"
                                         Background="#020806"
                                         BorderBrush="#11683f"
                                         Foreground="#dcf3e7"
                                         Padding="12"/>
                                <StackPanel Spacing="10" Margin="0,8,0,0">
                                    <TextBlock Text="Agent-Up Desktop writes this file for you, then checks it before continuing."
                                               Foreground="#acd0bd"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="TutorialCreateAgentUpJsonButton"
                                            HorizontalAlignment="Left"
                                            Command="{Binding Tutorial.CreateAgentUpJsonCommand}">
                                        <Border Classes="tutorialSecondaryButton">
                                            <TextBlock Classes="tutorialButtonText" Text="Create agent-up.json"/>
                                        </Border>
                                    </Button>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Tutorial.ShowAgentUpJsonCheckSection}"
                                            Spacing="10"
                                            Margin="0,8,0,0">
                                    <TextBlock Text="Now check that agent-up.json exists and can be parsed."
                                               Foreground="#acd0bd"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="TutorialCheckAgentUpJsonButton"
                                            Command="{Binding Tutorial.CheckAgentUpJsonCommand}"
                                            HorizontalAlignment="Left">
                                        <Border Classes="tutorialSecondaryButton">
                                            <TextBlock Classes="tutorialButtonText" Text="Check agent-up.json"/>
                                        </Border>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowStartStep}" Spacing="16">
                                <TextBlock Text="Step 6: Start the workspace"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="Starting the workspace registers it with the "/>
                                    <Run Text="Agent-Up Server" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=", launches the declared apps, and assigns ports from the workspace range."/>
                                </TextBlock>
                                <StackPanel Spacing="10" Margin="0,8,0,0">
                                    <Button x:Name="TutorialStartWorkspaceButton"
                                            Command="{Binding Tutorial.StartWorkspaceCommand}"
                                            HorizontalAlignment="Left">
                                        <Border Classes="tutorialSecondaryButton">
                                            <TextBlock Classes="tutorialButtonText" Text="Run agent-up start"/>
                                        </Border>
                                    </Button>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Tutorial.ShowCommandOutput}"
                                            Spacing="10"
                                            Margin="0,8,0,0">
                                    <TextBlock Text="Command output"
                                               Foreground="#acd0bd"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                    <TextBox Text="{Binding Tutorial.CommandOutput}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             MinHeight="120"
                                             Background="#020806"
                                             BorderBrush="#11683f"
                                             Foreground="#dcf3e7"
                                             Padding="12"/>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Tutorial.ShowWorkspaceCheckSection}"
                                            Spacing="10"
                                            Margin="0,8,0,0">
                                    <TextBlock Text="The command succeeded. Now ask the Server whether it sees React, Express, and Postgres."
                                               Foreground="#acd0bd"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="TutorialCheckWorkspaceButton"
                                            Command="{Binding Tutorial.CheckWorkspaceCommand}"
                                            HorizontalAlignment="Left">
                                        <Border Classes="tutorialSecondaryButton">
                                            <TextBlock Classes="tutorialButtonText" Text="Check Workspace"/>
                                        </Border>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowDuplicateStep}" Spacing="16">
                                <TextBlock Text="Step 7: Duplicate the workspace"
                                           Foreground="#f5fbf7"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="15">
                                    <Run Text="Now Agent-Up copies "/>
                                    <Run Text="example-agent1 to example-agent2" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" under the same tutorial root and starts it too. This proves two agents can run the same project without port collisions."/>
                                </TextBlock>
                                <Button x:Name="TutorialCreateDuplicateButton"
                                        Command="{Binding Tutorial.MarkDuplicateStartedCommand}"
                                        HorizontalAlignment="Left">
                                    <Border Classes="tutorialSecondaryButton">
                                        <TextBlock Classes="tutorialButtonText" Text="Create and Start example-agent2"/>
                                    </Border>
                                </Button>
                                <StackPanel IsVisible="{Binding Tutorial.ShowDuplicateCheckSection}"
                                            Spacing="10"
                                            Margin="0,8,0,0">
                                    <TextBlock Text="The duplicate has started. Check that both workspaces are registered and every allocated port is unique."
                                               Foreground="#acd0bd"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="TutorialCheckDuplicateButton"
                                            Command="{Binding Tutorial.CheckDuplicateCommand}"
                                            HorizontalAlignment="Left">
                                        <Border Classes="tutorialSecondaryButton">
                                            <TextBlock Classes="tutorialButtonText" Text="Check Duplicate"/>
                                        </Border>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding Tutorial.ShowSuccessStep}" Spacing="16">
                                <TextBlock Text="You just proved the core Agent-Up workflow"
                                           Foreground="#f5fbf7"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="16">
                                    <Run Text="Agent-Up created "/>
                                    <Run Text="two isolated workspaces" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=" from the same JavaScript project, started the same React, Express, and Postgres components in both, and let the Server allocate ports without collisions."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="16">
                                    <Run Text="The second workspace also has "/>
                                    <Run Text="different seeded product data" FontWeight="Bold" Foreground="#f5fbf7"/>
                                    <Run Text=", so the React dashboard table makes it obvious which isolated environment you are viewing."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#c6ddd2"
                                           FontSize="16">
                                    <Run Text="That matters because agents can now work in parallel on duplicate environments while sharing the same runtime rules: "/>
                                    <Run Text="workspace identity, process lifecycle, Docker, browser profiles, diagnostics, and ports all stay Server-owned." FontWeight="Bold" Foreground="#f5fbf7"/>
                                </TextBlock>
                            </StackPanel>

                            <Border IsVisible="{Binding Tutorial.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#020806"
                                    BorderBrush="#11683f"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">
                                <TextBlock x:Name="TutorialStatusMessage"
                                           Text="{Binding Tutorial.StatusMessage}"
                                           Foreground="#d3eadf"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                          ColumnSpacing="10">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Tutorial.CurrentStep, StringFormat='Step {0} of 8'}"
                                   Foreground="#2bf27a"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Command="{Binding Tutorial.BackCommand}"
                                IsEnabled="{Binding Tutorial.CanGoBack}">
                            <Border Classes="tutorialSecondaryButton">
                                <TextBlock Classes="tutorialButtonText" Text="Back"/>
                            </Border>
                        </Button>
                        <Button Grid.Column="3"
                                x:Name="TutorialContinueButton"
                                Command="{Binding Tutorial.ContinueCommand}"
                                IsEnabled="{Binding Tutorial.CanContinue}">
                            <Border Classes="tutorialButton">
                                <TextBlock Classes="tutorialButtonText"
                                           Text="{Binding Tutorial.PrimaryButtonText}"/>
                            </Border>
                        </Button>
                        <Button Grid.Column="4"
                                x:Name="SkipTutorialButton"
                                Command="{Binding Tutorial.SkipCommand}">
                            <Border Classes="tutorialSecondaryButton">
                                <TextBlock Classes="tutorialButtonText" Text="Skip"/>
                            </Border>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Panel>
    </Grid>
    </Border>
</Window>
