<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgentUp.Desktop.Features.Workspaces.ViewModels"
        x:Class="AgentUp.Desktop.Features.Workspaces.Views.MainWindow"
        Width="1100" Height="700"
        MinWidth="640" MinHeight="400"
        Title="Agent-Up"
        Background="#0d0d0f">

    <Window.Styles>
        <!-- Strip default ListBox chrome -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Strip default Button chrome -->
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Workspace entry: normal / hover / selected -->
        <Style Selector="Border.wsEntry">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsEntry">
            <Setter Property="Background" Value="#1a1a28"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsEntry">
            <Setter Property="Background" Value="#1e1c3a"/>
        </Style>

        <!-- Collapsed avatar: highlight selected -->
        <Style Selector="Border.wsAvatar">
            <Setter Property="Background" Value="#22222e"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsAvatar">
            <Setter Property="Background" Value="#2a2846"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsAvatar">
            <Setter Property="Background" Value="#1e1c3a"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Width="{Binding SidebarWidth}"
                Background="#16161a"
                BorderBrush="#252530"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Collapse toggle (docked bottom so it stays put) -->
                <Button x:Name="SidebarToggle"
                        DockPanel.Dock="Bottom"
                        Command="{Binding ToggleSidebarCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,6,10,14">
                    <Border Width="26" Height="26" CornerRadius="5" Background="#22222e">
                        <TextBlock Text="{Binding SidebarToggleIcon}"
                                   Foreground="#5a5a72"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- Header label (expanded only) -->
                <Border DockPanel.Dock="Top"
                        Padding="16,14,16,6"
                        IsVisible="{Binding IsSidebarExpanded}">
                    <TextBlock Text="Workspaces"
                               Foreground="#4a4a62"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Spacer above avatar list (collapsed only) -->
                <Border DockPanel.Dock="Top"
                        Height="14"
                        IsVisible="{Binding IsSidebarCollapsed}"/>

                <!-- Expanded workspace list -->
                <ScrollViewer x:Name="WorkspaceListExpanded"
                              IsVisible="{Binding IsSidebarExpanded}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox
                             ItemsSource="{Binding Workspaces}"
                             SelectedItem="{Binding SelectedWorkspace}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border Padding="8,2">
                                    <Border Classes="wsEntry" CornerRadius="6" Padding="10,8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#dcdce8"
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Branch}"
                                                       Foreground="#5a5a72"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding WorktreePath}"
                                                       Foreground="#3a3a50"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Collapsed avatar list -->
                <ScrollViewer x:Name="WorkspaceListCollapsed"
                              IsVisible="{Binding IsSidebarCollapsed}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox
                             ItemsSource="{Binding Workspaces}"
                             SelectedItem="{Binding SelectedWorkspace}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border HorizontalAlignment="Center" Padding="0,4">
                                    <Border Classes="wsAvatar"
                                            Width="36" Height="36"
                                            CornerRadius="8"
                                            ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="#7c6cf8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ── Main content ───────────────────────────────────────────────────── -->
        <Border Grid.Column="1" Background="#0d0d0f">
            <Panel>

                <!-- Loading -->
                <TextBlock x:Name="LoadingIndicator"
                           IsVisible="{Binding IsLoading}"
                           Text="Connecting to server…"
                           Foreground="#4a4a62"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Error -->
                <Panel x:Name="ErrorPanel"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#130e10"
                            BorderBrush="#3d1e28"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24,20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#b85a5a"
                                       FontSize="13"/>
                            <Button Command="{Binding RefreshCommand}"
                                    HorizontalAlignment="Center">
                                <Border Background="#22222e" CornerRadius="5" Padding="14,7">
                                    <TextBlock Text="Retry" Foreground="#dcdce8" FontSize="12"/>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>
                </Panel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            IsVisible="{Binding ShowEmptyState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="No workspaces registered"
                               Foreground="#2e2e42"
                               FontSize="16"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Run  agent-up register  in your project directory to get started."
                               Foreground="#222230"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Workspace detail -->
                <Border x:Name="WorkspaceDetail"
                        IsVisible="{Binding SelectedWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Padding="40,32">
                    <StackPanel DataContext="{Binding SelectedWorkspace}" Spacing="0">

                        <TextBlock x:Name="DetailWorkspaceName"
                                   Text="{Binding DisplayName}"
                                   Foreground="#dcdce8"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- State badge -->
                        <Border CornerRadius="5"
                                Padding="10,4"
                                HorizontalAlignment="Left"
                                Background="#182218"
                                Margin="0,0,0,32">
                            <TextBlock Text="{Binding State}"
                                       Foreground="#4cbe78"
                                       FontSize="12"
                                       FontWeight="Medium"/>
                        </Border>

                        <!-- Detail rows -->
                        <Grid ColumnDefinitions="110,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Branch"
                                       Foreground="#3e3e54" FontSize="12" Margin="0,0,0,14"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Branch}"
                                       Foreground="#dcdce8" FontSize="12" Margin="0,0,0,14"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Worktree"
                                       Foreground="#3e3e54" FontSize="12" Margin="0,0,0,14"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding WorktreePath}"
                                       Foreground="#dcdce8" FontSize="12" Margin="0,0,0,14"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Repository"
                                       Foreground="#3e3e54" FontSize="12" Margin="0,0,0,14"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding RepositoryPath}"
                                       Foreground="#dcdce8" FontSize="12" Margin="0,0,0,14"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="State"
                                       Foreground="#3e3e54" FontSize="12" Margin="0,0,0,14"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding State}"
                                       Foreground="#dcdce8" FontSize="12" Margin="0,0,0,14"/>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="ID"
                                       Foreground="#3e3e54" FontSize="12" Margin="0,0,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding Id}"
                                       Foreground="#5a5a72" FontSize="11" Margin="0,0,0,0"
                                       FontFamily="Consolas,Courier New,monospace"/>
                        </Grid>

                    </StackPanel>
                </Border>

            </Panel>
        </Border>
    </Grid>
</Window>
