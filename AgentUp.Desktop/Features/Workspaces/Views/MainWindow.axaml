<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgentUp.Desktop.Features.Workspaces.ViewModels"
        xmlns:appVm="using:AgentUp.Desktop.Features.Applications.ViewModels"
        xmlns:portVm="using:AgentUp.Desktop.Features.Ports.ViewModels"
        x:Class="AgentUp.Desktop.Features.Workspaces.Views.MainWindow"
        Width="1100" Height="700"
        MinWidth="640" MinHeight="400"
        Title="Agent-Up"
        Background="#0d0d0f">

    <Window.DataTemplates>
        <!-- Console sub-tab -->
        <DataTemplate DataType="portVm:ConsoleSubTabViewModel">
            <Border Classes="subTab" Padding="10,7">
                <TextBlock Text="Console"
                           Foreground="#dcdce8"
                           FontSize="11"
                           FontWeight="Medium"/>
            </Border>
        </DataTemplate>

        <!-- Port sub-tab -->
        <DataTemplate DataType="portVm:PortSubTabViewModel">
            <Border Classes="subTab" Padding="10,7">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Border Width="6" Height="6"
                            CornerRadius="3"
                            Background="{Binding StatusColor}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Label}"
                               Foreground="#dcdce8"
                               FontSize="11"
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <!-- Strip default ListBox chrome -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Strip default Button chrome -->
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Application tab bar -->
        <Style Selector="Border.appTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.appTab">
            <Setter Property="Background" Value="#141424"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.appTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#7c6cf8"/>
        </Style>

        <!-- Sub-navbar tab -->
        <Style Selector="Border.subTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.subTab">
            <Setter Property="Background" Value="#141424"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.subTab">
            <Setter Property="BorderBrush" Value="#5a50c8"/>
        </Style>

        <!-- Workspace entry: normal / hover / selected -->
        <Style Selector="Border.wsEntry">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsEntry">
            <Setter Property="Background" Value="#1a1a28"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsEntry">
            <Setter Property="Background" Value="#1e1c3a"/>
        </Style>

        <!-- Collapsed avatar: highlight selected -->
        <Style Selector="Border.wsAvatar">
            <Setter Property="Background" Value="#22222e"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.wsAvatar">
            <Setter Property="Background" Value="#2a2846"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.wsAvatar">
            <Setter Property="Background" Value="#1e1c3a"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Width="{Binding Sidebar.Width}"
                Background="#16161a"
                BorderBrush="#252530"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Collapse toggle (docked to very bottom) -->
                <Button x:Name="SidebarToggle"
                        DockPanel.Dock="Bottom"
                        Command="{Binding Sidebar.ToggleCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,6,10,14">
                    <Border Width="26" Height="26" CornerRadius="5" Background="#22222e">
                        <TextBlock Text="{Binding Sidebar.ToggleIcon}"
                                   Foreground="#5a5a72"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- Reload button (collapsed only, sits just above toggle) -->
                <Button x:Name="ReloadButtonCollapsed"
                        DockPanel.Dock="Bottom"
                        Command="{Binding Sidebar.RefreshCommand}"
                        IsVisible="{Binding Sidebar.IsCollapsed}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,2"
                        ToolTip.Tip="Reload workspaces">
                    <Border Width="26" Height="26" CornerRadius="5" Background="#22222e">
                        <TextBlock Text="↺"
                                   Foreground="#5a5a72"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- Header: label + reload button (expanded only) -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12,10,6"
                        IsVisible="{Binding Sidebar.IsExpanded}">
                    <DockPanel>
                        <Button x:Name="ReloadButton"
                                DockPanel.Dock="Right"
                                Command="{Binding Sidebar.RefreshCommand}"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Reload workspaces">
                            <Border Width="22" Height="22" CornerRadius="4" Background="#1c1c26">
                                <TextBlock Text="↺"
                                           Foreground="#5a5a72"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Button>
                        <TextBlock Text="Workspaces"
                                   Foreground="#4a4a62"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Spacer above avatar list (collapsed only) -->
                <Border DockPanel.Dock="Top"
                        Height="14"
                        IsVisible="{Binding Sidebar.IsCollapsed}"/>

                <!-- Expanded workspace list -->
                <ScrollViewer x:Name="WorkspaceListExpanded"
                              IsVisible="{Binding Sidebar.IsExpanded}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox
                             ItemsSource="{Binding Sidebar.Workspaces}"
                             SelectedItem="{Binding Sidebar.SelectedWorkspace}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border Padding="8,2">
                                    <Border Classes="wsEntry" CornerRadius="6" Padding="10,8">
                                        <StackPanel Spacing="3">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left"
                                                        Width="6" Height="6"
                                                        CornerRadius="3"
                                                        Background="{Binding StateColor}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,7,0"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="#dcdce8"
                                                           FontSize="13"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Branch}"
                                                       Foreground="#5a5a72"
                                                       FontSize="11"
                                                       Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Collapsed avatar list -->
                <ScrollViewer x:Name="WorkspaceListCollapsed"
                              IsVisible="{Binding Sidebar.IsCollapsed}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox
                             ItemsSource="{Binding Sidebar.Workspaces}"
                             SelectedItem="{Binding Sidebar.SelectedWorkspace}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceItemViewModel">
                                <Border HorizontalAlignment="Center" Padding="0,4">
                                    <Border Classes="wsAvatar"
                                            Width="36" Height="36"
                                            CornerRadius="8"
                                            ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="#7c6cf8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ── Main content ───────────────────────────────────────────────────── -->
        <Border Grid.Column="1" Background="#0d0d0f">
            <Panel>

                <!-- Loading -->
                <TextBlock x:Name="LoadingIndicator"
                           IsVisible="{Binding Sidebar.IsLoading}"
                           Text="Connecting to server…"
                           Foreground="#4a4a62"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Error -->
                <Panel x:Name="ErrorPanel"
                       IsVisible="{Binding Sidebar.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#130e10"
                            BorderBrush="#3d1e28"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24,20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="{Binding Sidebar.ErrorMessage}"
                                       Foreground="#b85a5a"
                                       FontSize="13"/>
                            <Button Command="{Binding Sidebar.RefreshCommand}"
                                    HorizontalAlignment="Center">
                                <Border Background="#22222e" CornerRadius="5" Padding="14,7">
                                    <TextBlock Text="Retry" Foreground="#dcdce8" FontSize="12"/>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>
                </Panel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            IsVisible="{Binding Sidebar.ShowEmptyState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="No workspaces registered"
                               Foreground="#2e2e42"
                               FontSize="16"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Run  agent-up register  in your project directory to get started."
                               Foreground="#222230"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Workspace detail: app tabs + sub-navbar + content -->
                <Border x:Name="WorkspaceDetail"
                        IsVisible="{Binding Sidebar.SelectedWorkspace, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Grid RowDefinitions="Auto,Auto,*">

                        <!-- Application tab bar -->
                        <Border Grid.Row="0"
                                Background="#12121a"
                                BorderBrush="#1e1e2a"
                                BorderThickness="0,0,0,1">
                            <ListBox x:Name="ApplicationTabs"
                                     ItemsSource="{Binding Applications.Applications}"
                                     SelectedItem="{Binding Applications.SelectedApplication}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="appVm:ApplicationViewModel">
                                        <Border Classes="appTab" Padding="14,10">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="6" Height="6" CornerRadius="3"
                                                        Background="{Binding StateColor}"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#c0c0d8"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Sub-navbar: Console + port tabs for the selected app -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding Applications.SelectedApplication, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="#0e0e16"
                                BorderBrush="#1e1e2a"
                                BorderThickness="0,0,0,1"
                                Padding="16,0">
                            <ListBox x:Name="SubNavBar"
                                     ItemsSource="{Binding SubTabs}"
                                     SelectedItem="{Binding SelectedSubTab}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <!-- Templates resolved from Window.DataTemplates by type -->
                            </ListBox>
                        </Border>

                        <!-- Content area -->
                        <Panel Grid.Row="2">

                            <!-- No applications configured -->
                            <StackPanel IsVisible="{Binding Applications.SelectedApplication, Converter={x:Static ObjectConverters.IsNull}}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="No apps in this workspace"
                                           Foreground="#2e2e42"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Add an agent-up.json with an applications list."
                                           Foreground="#222230"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Console output -->
                            <ScrollViewer x:Name="ConsolePane"
                                          IsVisible="{Binding ShowConsole}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ConsoleOutput"
                                              ItemsSource="{Binding Console.Lines}"
                                              Margin="20,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       FontSize="11"
                                                       Foreground="#7878a0"
                                                       TextWrapping="NoWrap"
                                                       Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Port view placeholder -->
                            <Border x:Name="PortPane"
                                    IsVisible="{Binding ShowPortView}"
                                    Background="Transparent"/>

                        </Panel>

                    </Grid>
                </Border>

            </Panel>
        </Border>
    </Grid>
</Window>
